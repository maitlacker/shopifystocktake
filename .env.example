# Shopify
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Google OAuth — create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# Session — generate a long random string
SESSION_SECRET=change-me-to-a-long-random-string

# Your app's public URL (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-app.railway.app
APP_URL=http://localhost:3000

# Railway injects DATABASE_URL automatically — set manually for local dev
DATABASE_URL=postgresql://user:password@localhost:5432/warehouse

# Server
PORT=3000
NODE_ENV=production
